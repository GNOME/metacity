#: libmetacity/meta-color-spec.c:246
#, c-format
msgid ""
"GTK custom color specification must have color name and fallback in "
"parentheses, e.g. gtk:custom(foo,bar); could not parse '%s'"
msgstr ""
"GTK қолданушы түсінің сипаттамасында жақша ішінде түс аты мен баламасы болуы "
"керек, мысалы, gtk:custom(foo,bar); '%s' талданбады"

#: libmetacity/meta-color-spec.c:260
#, c-format
msgid ""
"Invalid character '%c' in color_name parameter of gtk:custom, only A-Za-z0-9-_ "
"are valid"
msgstr ""
"gtk:custom функциясының color_name параметрінде жарамсыз '%c' таңбасы бар, тек "
"A-Za-z0-9-_ рұқсат етілген"

#: libmetacity/meta-color-spec.c:277
#, c-format
msgid ""
"Gtk:custom format is 'gtk:custom(color_name,fallback)', '%s' does not fit the "
"format"
msgstr ""
"Gtk:custom пішімі: 'gtk:custom(color_name,fallback)', '%s' бұл пішімге сәйкес "
"келмейді"

#: libmetacity/meta-color-spec.c:310
#, c-format
msgid ""
"GTK color specification must have the state in brackets, e.g. gtk:fg[NORMAL] "
"where NORMAL is the state; could not parse '%s'"
msgstr ""
"GTK түс сипаттамасында жақша ішінде күй болуы керек, мысалы, gtk:fg[NORMAL], "
"мұндағы NORMAL — күй; '%s' талданбады"

#: libmetacity/meta-color-spec.c:323
#, c-format
msgid ""
"GTK color specification must have a close bracket after the state, e.g. "
"gtk:fg[NORMAL] where NORMAL is the state; could not parse '%s'"
msgstr ""
"GTK түс сипаттамасында күйден кейін жабылатын жақша болуы керек, мысалы, "
"gtk:fg[NORMAL], мұндағы NORMAL — күй; '%s' талданбады"

#: libmetacity/meta-color-spec.c:332
#, c-format
msgid "Did not understand state '%s' in color specification"
msgstr "Түс сипаттамасындағы '%s' күйі түсініксіз"

#: libmetacity/meta-color-spec.c:344
#, c-format
msgid "Did not understand color component '%s' in color specification"
msgstr "Түс сипаттамасындағы '%s' түс құраушысы түсініксіз"

#: libmetacity/meta-color-spec.c:370
#, c-format
msgid ""
"Blend format is 'blend/bg_color/fg_color/alpha', '%s' does not fit the format"
msgstr ""
"Араластыру пішімі: 'blend/bg_color/fg_color/alpha', '%s' бұл пішімге сәйкес "
"келмейді"

#: libmetacity/meta-color-spec.c:380
#, c-format
msgid "Could not parse alpha value '%s' in blended color"
msgstr "Араластырылған түстегі '%s' альфа мәнін талдау мүмкін емес"

#: libmetacity/meta-color-spec.c:389
#, c-format
msgid "Alpha value '%s' in blended color is not between 0.0 and 1.0"
msgstr "Араластырылған түстегі '%s' альфа мәні 0.0 мен 1.0 аралығында емес"

#: libmetacity/meta-color-spec.c:432
#, c-format
msgid "Shade format is 'shade/base_color/factor', '%s' does not fit the format"
msgstr ""
"Көлеңкелеу пішімі: 'shade/base_color/factor', '%s' бұл пішімге сәйкес келмейді"

#: libmetacity/meta-color-spec.c:442
#, c-format
msgid "Could not parse shade factor '%s' in shaded color"
msgstr "Көлеңкеленген түстегі '%s' көлеңкелеу коэффициентін талдау мүмкін емес"

#: libmetacity/meta-color-spec.c:451
#, c-format
msgid "Shade factor '%s' in shaded color is negative"
msgstr "Көлеңкеленген түстегі '%s' көлеңкелеу коэффициенті теріс мән"

#: libmetacity/meta-color-spec.c:477
#, c-format
msgid "Could not parse color '%s'"
msgstr "'%s' түсін талдау мүмкін емес"

#: libmetacity/meta-draw-spec.c:201
#, c-format
msgid "Coordinate expression contains character '%s' which is not allowed"
msgstr "Координаталық өрнекте рұқсат етілмеген '%s' таңбасы бар"

#: libmetacity/meta-draw-spec.c:228
#, c-format
msgid ""
"Coordinate expression contains floating point number '%s' which could not be "
"parsed"
msgstr "Координаталық өрнекте талдау мүмкін емес жылжымалы нүктелі '%s' саны бар"

#: libmetacity/meta-draw-spec.c:241
#, c-format
msgid "Coordinate expression contains integer '%s' which could not be parsed"
msgstr "Координаталық өрнекте талдау мүмкін емес '%s' бүтін саны бар"

#: libmetacity/meta-draw-spec.c:368
#, c-format
msgid ""
"Coordinate expression contained unknown operator at the start of this text: "
"\"%s\""
msgstr "Координаталық өрнекте мына мәтіннің басында белгісіз оператор бар: \"%s\""

#: libmetacity/meta-draw-spec.c:424
msgid "Coordinate expression was empty or not understood"
msgstr "Координаталық өрнек бос немесе түсініксіз"

#: libmetacity/meta-draw-spec.c:586
#, c-format
msgid "Coordinate expression had unknown variable or constant '%s'"
msgstr "Координаталық өрнекте белгісіз '%s' айнымалысы немесе тұрақтысы бар"

#: libmetacity/meta-draw-spec.c:638 libmetacity/meta-draw-spec.c:648
